    width: 180px;
    height: 445px;
    flex-direction: column;
    align-items: center;
    z-index: 2;
}

.content {
    width: 174px;
    justify-content: center;
    align-items: center;
    padding: 10px;
    background-color: rgba(255, 255, 255, 0.726);
    border-radius: 9px;
    border: 1px solid #e0e0e0;
    margin: 9px;
}

.mid {
    font-size: 28px;
    color: #000;
    font-weight: 800;
}

.mid1 {
    text-align: center;
    width: 212px;
    background-color: #f1dd28;
