<template> 
    <div class="page"> 
        <img class="bcg" src="/common/bcgi/空_夕_夏.jpg"></img> 
        <img class="bt" src="/common/bt.png"></img> 
        <img class="hd" src="/common/hd.png"></img> 
        
        <scroll id="mainScroll" class="scroll" scroll-y="{{true}}" if="{{!showAS}}">
            <div class="header">
                <text class="title">更多</text> 
            </div>
            <div class="content" onclick="lctruote">
                <text class="mid">流程图</text>
            </div>
            <div class="content" onclick="cgruote">
                <text class="mid">鉴赏模式</text>
            </div>
            <div class="content" onclick="afterstoryshow">
                <text class="mid">后日谈</text>
            </div>
        </scroll>
        
        <div class="page1" if="{{showAS}}">
            <img class="bcg" src="/common/bcgi/空_夕_夏.jpg"></img> 
            <img class="bt" src="/common/bt.png"></img> 
            <img class="hd" src="/common/hd.png"></img> 

            <div class="header">
                <text class="title">后日谈</text> 
            </div>

            <swiper class="as-swiper" index="{{asIndex}}" indicator="false" loop="true" onchange="onSwiperChange">
                <div class="as-page" for="{{afterStories}}" tid="name">
                    <image class="cig" src="{{$item.img}}"></image>
                    <text class="mid1">{{$item.name}}</text>
                    <div class="startBtn">
                        <text class="startText" onclick="loadStart($item.line)">开始</text>
                    </div>
                </div>
            </swiper>
        </div>
        
        <!-- 返回按钮 -->
        <div class="back-btn-wrap" onclick="back">
            <text class="back-btn-text">返回</text>
        </div>
    </div> 
</template> 

<script> 
import storage from '@system.storage'
import router from '@system.router' 

export default { 
    data: { 
        showAS: false, 
        asIndex: 0,
        afterStories: [
            { name: '阳见', img: '/common/cimg/hz02_1.png', line: 24546 },
            { name: '杏珠', img: '/common/cimg/xz05_1.png', line: 54247 },
            { name: '月望', img: '/common/cimg/yw02_1.png', line: 67285 },
            { name: '莉莉子', img: '/common/cimg/llz01_1.png', line: 34397 },
            { name: '美玖', img: '/common/cimg/mj01_1.png', line: 45171 },
            { name: '那优花', img: '/common/cimg/nyh01_1.png', line: 39924 },
        ],
    }, 
    
    onSwiperChange(e) {
        this.asIndex = e.index;
    },
    
    // 返回逻辑
    back() { 
        if (!this.showAS) {
            router.back({ 
                uri: 'pages/index', 
            });
        } else {
            this.showAS = false;
        }
    }, 
    
    // 跳转到流程图页面
    lctruote() {
        router.push({
            uri: 'pages/lct',
        });
    },
    
    // 跳转到CG鉴赏页面
    cgruote() {
        router.push({
            uri: 'pages/cgs',
        });
    },
    
    // 显示后日谈选择界面
    afterstoryshow() {
        this.showAS = true;
    },
    
    // 开始后日谈（需要实现具体逻辑）

    loadStart(a){
    storage.set({
      key: 'readProgress',
      value: JSON.stringify(a),
      success: () => {},
      fail: () => {}
    });
    router.replace({ uri:'pages/detail' });
  },
}; 
</script> 

