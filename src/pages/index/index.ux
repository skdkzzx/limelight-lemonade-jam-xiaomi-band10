  text-align: center;
}
.load{
  margin-top: 8px;
  font-size: 24px;
  color: #000;
  font-weight: 800;
  width: 210px;
  background-color: rgba(226, 216, 120, 0.267);
  text-align: center;
  padding: 12px 0;
  border-radius: 8px;
}
.load2{
  margin-top: 9px;
