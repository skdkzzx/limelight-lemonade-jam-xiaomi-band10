  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  bottom: 15px;
  right: 25px;
  position: absolute;
}
.settings{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  top: 15px;
  right: 32px;
  position: absolute;
}
.reset{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  bottom: 130px;
  right: 6px;
  position: absolute;

}
.back{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  bottom: 45px;
  right: 6px;
  position: absolute;

}
.group-1{
  top:300px;
  flex-direction: column;
  width: 90%;
}
.mid{
  margin-bottom:9px;
  font-size: 24px;
  color: #000;
  font-weight: 800;
}
.bc{
  position: absolute;
  width: 212px;
  height: 490px;
  top: 0;
  left: 0;
  background-color: rgb(47, 52, 116);
  z-index: -1;
}
.page1{
  position: absolute;
  background-color: #ffffff;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  width: 100%;
  height: 490px;
  top: 0;
  left: 0;
  z-index: 10;
}
.time-bar{
  width: 212px;
  height: 35px;
  justify-content: center;
  align-items: center;
  background-color: rgba(0, 0, 0, 0.05);
  margin-top: 25px;
}
.time-text{
  font-size: 18px;
