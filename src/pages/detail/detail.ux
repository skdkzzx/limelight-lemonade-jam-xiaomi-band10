    currentPageId: 1,
    
    // 选择选项颜色
    choose1Color: '#ffffff',
    choose2Color: '#ffffff',
    choose3Color: '#ffffff',
    choose4Color: '#ffffff',
    
    // 快进快退页面缓存
    quickNavigationCache: {},
