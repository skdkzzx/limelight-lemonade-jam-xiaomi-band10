          </div>
        </div>
        <!-- 初次访问时显示的底部按钮 -->
        <text class="acknowledge-btn" if="{{isFirstVisit}}"  onclick="acknowledge">我已知晓</text>
        <div class="scroll-bottom-space"></div>
      </scroll>
      
      <!-- 底部居中返回按钮：仅非初次访问时显示 -->
      <div class="back-btn-wrap" if="{{!isFirstVisit}}" onclick="back">
        <text class="back-btn-text">返回</text>
      </div>
    </div> 
  </template> 
  
  <script> 
  import router from '@system.router'
  import storage from '@system.storage'
  
  export default { 
    data: {
      isFirstVisit: true    // 默认为初次访问，待读取存储后更新
    }, 
    noax(e) {
      if (e.direction === 'right' || e.direction === 'left') return;
    },
    onInit() {
      // 读取是否已访问过 about 页面
      storage.get({
        key: 'about_visited2',
        success: (data) => {
          if (data === 'true') {
            this.isFirstVisit = false;  
          } else {
            this.isFirstVisit = true; 
          }
        },
        fail: () => {
          // 读取失败（键不存在），视为初次访问
          this.isFirstVisit = true;
        }
      });
    },
    
    back() { 
      router.back({ 
        uri: 'pages/index'
      }) 
    },
    setting() { 
      router.replace({ 
        uri: 'pages/settings'
      }) 
    },
    acknowledge() {
      // 标记已访问
      storage.set({
        key: 'about_visited2',
        value: 'true',
        success: () => {
          this.setting();   // 返回主页
        },
        fail: () => {
          this.setting();   // 即使存储失败也返回
        }
      });
    }
  }; 
  </script> 
  
