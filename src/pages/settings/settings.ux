<template> 
    <div class="page" onswipe="onPageSwipe"> 
        
    <img class="bcg"src="/common/bcgi/空_夕_夏.jpg"></img> 
    <img class="bt"src="/common/bt.png"></img> 
    <img class="hd"src="/common/hd.png"></img> 
    
    <scroll id="mainScroll" class="scroll" scroll-y="{{true}}" >
        <div class="header">
            <text class="title">设置</text>  
        </div>
        
        <!-- 文本播放速度设置 -->
        <div class="setting-section">
            <text class="section-title">文本播放速度</text> 
            <slider class="slider" min="5" max="40" step="5" value="{{textSpeed}}" @change="updateTextSpeed"/> 
            <div class="slider-labels">
                <text class="label">快</text>
                <text class="current-value">当前速度:{{textSpeed}}ms/字</text> 
                <text class="label">慢</text>
            </div>

            <text class="section-title">字体大小</text> 
            <slider class="slider" min="16" max="40" step="2" value="{{fontSize}}" @change="updateFontSize"/> 
            <div class="slider-labels">
                <text class="label">小</text>
                <text class="current-value">当前字体大小:{{fontSize}}px</text> 
                <text class="label">大</text>
            </div>

            <text class="section-title">角色名大小</text> 
            <slider class="slider" min="16" max="30" step="2" value="{{characterNameFontSize}}" @change="updateCharacterNameFontSize"/> 
            <div class="slider-labels">
                <text class="label">小</text>
                <text class="current-value">当前大小:{{characterNameFontSize}}px</text> 
                <text class="label">大</text>
            </div>
            
            <text class="section-title">自动播放速度</text> 
            <slider class="slider" min="500" max="3000" step="100" value="{{autoPlayDelay}}" @change="updateAutoSpeed"/> 
            <div class="slider-labels">
                <text class="label">快</text>
                <text class="current-value">当前速度:{{autoPlayDelay}}ms</text> 
                <text class="label">慢</text>
            </div>

            <text class="section-title">背景滚动速度</text> 
            <slider class="slider" min="1" max="10" step="1" value="{{bgScrollSpeed}}" @change="updateBgScrollSpeed"/> 
            <div class="slider-labels">
                <text class="label">慢</text>
                <text class="current-value">当前速度:{{bgScrollSpeed}}</text> 
                <text class="label">快</text>
            </div>
        </div>


        <div class="setting-section">
            <div class="switch-row">
                <text class="switch-label">屏幕常亮</text>
                <switch checked="{{screenAlwaysOn}}" class="switch" @change="onScreenAlwaysOnChange"></switch>
            </div>
            <div class="switch-row">
                <text class="switch-label">粗体</text>
                <switch checked="{{boldText}}" class="switch" @change="onBoldTextChange"></switch>
            </div>
            <div class="switch-row">
                <text class="switch-label2">仅跳过已读文本</text>
                <switch checked="{{skipOnlyRead}}" class="switch" @change="onSkipOnlyReadChange"></switch>
            </div>
        </div>


        <!-- 未读文本颜色设置 -->
        <div class="setting-section">
            <text class="section-title">未读文本颜色</text> 
            <div class="color-picker"> 
                <div class="color-option" for="{{unreadColors}}" onclick="selectUnreadColor($idx)"> 
                    <div class="color-circle" style="background-color: {{$item.color}};"></div> 
                    <!-- <text class="color-name">{{$item.name}}</text>  -->
                    <div class="color-check" if="{{$item.color === unreadColor}}"></div> 
                </div> 
            </div> 
            <text class="section-title">已读文本颜色</text> 
            <div class="color-picker"> 
                <div class="color-option" for="{{readColors}}" onclick="selectReadColor($idx)"> 
                    <div class="color-circle" style="background-color: {{$item.color}};"></div> 
                    <!-- <text class="color-name">{{$item.name}}</text>  -->
                    <div class="color-check" if="{{$item.color === readColor}}"></div> 
                </div> 
            </div> 
        </div>
        <div class="setting-section">
            <div class="switch-row">
                <text class="switch-label">隐藏模式</text>
                <switch checked="{{hiddenMode}}" class="switch" @change="onHiddenModeChange"></switch>
            </div>
            <text class="hint-text">开启后下次启动将显示黑屏伪装</text>
            <text class="hint-text">连续点击屏幕中央时钟20次进入</text>
        </div>
        <div class="setting-section">
            <text class="section-title">!!!用户数据慎重重置!!!</text> 
            <text class="reset" onclick="resetAllSettings">重置所有设置</text> 
            <text class="reset" onlongpress="resetUserData">长按重置用户数据</text> 
        </div>
    <!-- 颜色预览 -->
        <div class="setting-section">
            <text class="section-title">颜色预览</text> 
            <div class="preview-area"> 
                <text class="preview-text" style="font-size: {{fontSize}}px; color: {{unreadColor}}; font-weight: {{boldText ? 'bold' : 'normal'}}"> 
                    未读文本颜色预览
                </text> 
                <text class="preview-text" style="font-size: {{fontSize}}px; color: {{readColor}}; font-weight: {{boldText ? 'bold' : 'normal'}}"> 
                    已读文本颜色预览
                </text> 
            </div> 
        </div>
        
        <!-- 速度预览 -->
        <div class="setting-section">
            <text class="section-title">速度预览</text> 
            <div class="preview-area" onclick="startPreview"> 
                <text class="preview-text" style="font-size: {{fontSize}}px; font-weight: {{boldText ? 'bold' : 'normal'}}">{{previewText}}</text> 
            </div> 
            <text class="hint-text">点击预览区域测试效果</text> 
        </div>
        <div class="scroll-bottom-space"></div>
    </scroll>
        <div class="back-btn-wrap" onclick="back">
          <text class="back-btn-text">返回</text>
        </div>
    </div> 
</template> 

<script>
import router from '@system.router'
import storage from '@system.storage'
import prompt from '@system.prompt'
import { SETTINGS_CONFIG, DEFAULT_SAVE_SLOTS } from '../../common/config.js'

export default { 
    data: { 
        textSpeed: 15, 
        fontSize: 22,
        characterNameFontSize: 22,
        autoPlayDelay: 1600,
        screenAlwaysOn: true,
        boldText: false,
        skipOnlyRead: true,
        hiddenMode: false,
        bgScrollSpeed: 5,
        unreadColor: '#ffffff',
        readColor: '#ffffff',
        previewText: "点击这里预览文本播放效果", 
        previewTimeoutIds: [],
        unreadColors: [
            { name: '白色', color: '#ffffff' },
            { name: '淡蓝', color: '#a0d2ff' },
            { name: '淡灰', color: '#cccccc' },
            { name: '淡紫', color: '#e6a0ff' }
        ],
        readColors: [
            { name: '淡紫', color: '#e6a0ff' },
            { name: '蓝色', color: '#6688cc' },
            { name: '灰色', color: '#aaaaaa' },
            { name: '白色', color: '#ffffff' }
        ]
    }, 
    
    onInit() { 
        this.loadSettings();
    }, 
    
    onDestroy() { 
        this.clearAllTimeouts();
    }, 

    back() { 
        this.saveSettings();
        router.back();
    }, 
    
    onBackPress(){ 
        this.saveSettings();
        return false;
    },
    
    loadSettings() {
        const settings = SETTINGS_CONFIG;

        settings.forEach(({ key, prop, type }) => {
            storage.get({ 
                key, 
                success: (data) => { 
                    if (data !== null && data !== undefined && data !== '') {
                        if (type === 'number') this[prop] = Number(data);
                        else if (type === 'boolean') this[prop] = data === 'true';
                        else this[prop] = data;
                    } 
                } 
            });
        });
    },
    
    updateTextSpeed(e) { 
        this.textSpeed = e.progress;
    },
    
    updateFontSize(e) {
        this.fontSize = e.progress;
    },

    updateCharacterNameFontSize(e) {
        this.characterNameFontSize = e.progress;
    },
    
    updateAutoSpeed(e) {
        this.autoPlayDelay = e.progress;
    },
    
    onScreenAlwaysOnChange(e) {
        this.screenAlwaysOn = e.checked;
    },
    
    onBoldTextChange(e) {
        this.boldText = e.checked;
    },
    
    onSkipOnlyReadChange(e) {
        this.skipOnlyRead = e.checked;
    },
    
    onHiddenModeChange(e) {
        this.hiddenMode = e.checked;
    },
    
    updateBgScrollSpeed(e) {
        this.bgScrollSpeed = e.progress;
    },
    
    selectUnreadColor(index) {
        this.unreadColor = this.unreadColors[index].color;
    },
    
    selectReadColor(index) {
        this.readColor = this.readColors[index].color;
    },
    
    startPreview() { 
        this.clearAllTimeouts();
        this.previewText = "";
        const fullText = "这是一个文本播放速度的预览示例，您可以调整滑块来改变播放速度。";
        
        for (let i = 0; i <= fullText.length; i++) { 
            const timeoutId = setTimeout(() => { 
                this.previewText = fullText.substring(0, i);
                
                if (i === fullText.length) { 
                    const restartId = setTimeout(() => { 
                        this.startPreview();
                    }, 2000);
                    this.previewTimeoutIds.push(restartId);
                } 
            }, i * this.textSpeed * 0.5);
            
            this.previewTimeoutIds.push(timeoutId);
        } 
    }, 
    
    clearAllTimeouts() { 
        this.previewTimeoutIds.forEach(id => { 
            clearTimeout(id);
        });
        this.previewTimeoutIds = [];
    },
    
    // 重置所有设置
    resetAllSettings() {
        this.resetToDefaults();
        prompt.showToast({
            message: '所有设置已重置为默认值',
            duration: 2000
        });
    },
    
    // 重置用户数据
    resetUserData() {
        this.performUserDataReset();
        prompt.showToast({
            message: '用户数据重置中',
            duration: 2000
        })
    },
    
    // 执行用户数据重置（适配新的分块存储方式）
    async performUserDataReset() {
        storage.set({ key: 'readProgress', value: '1' });
        
        const blockDeletePromises = [];
        for (let i = 0; i < 150; i++) {
            blockDeletePromises.push(new Promise((resolve) => {
                storage.delete({ key: `readBlock_${i}`, success: () => resolve(true), fail: () => resolve(true) });
            }));
        }
        
        storage.set({ key: 'readPages', value: JSON.stringify({}) });
        storage.set({ key: 'branchChoices', value: JSON.stringify({}) });
        
        const savePromises = [];
        for (let i = 1; i <= 30; i++) {
            savePromises.push(new Promise((resolve) => {
                storage.set({ key: `p${i}`, value: '1', success: () => resolve(true), fail: () => resolve(false) });
            }));
        }
        
        storage.set({
            key: 'saveSlots',
            value: JSON.stringify(DEFAULT_SAVE_SLOTS)
        });
        
        try {
            await Promise.all([...blockDeletePromises, ...savePromises]);
            prompt.showToast({ message: '用户数据已重置', duration: 3000 });
        } catch (error) {
            console.error('重置用户数据过程中出错:', error);
            prompt.showToast({ message: '重置过程中出现错误', duration: 3000 });
        }
    },
    
    resetToDefaults() {
        this.textSpeed = 15;
        this.fontSize = 22;
        this.autoPlayDelay = 1600;
        this.screenAlwaysOn = true;
        this.boldText = false;
        this.skipOnlyRead = true;
        this.hiddenMode = false;
        this.unreadColor = '#ffffff';
        this.readColor = '#ffffff';
        
        this.clearAllTimeouts();
        this.previewText = "点击这里预览文本播放效果";
        
        this.saveSettings();
    },
    
    onPageSwipe(e) {
        if (e.direction === 'right' || e.direction === 'left') return;
        this.saveSettings();
    },
    saveSettings() {
        const settings = SETTINGS_CONFIG.map(({ key, prop }) => ({
            key,
            value: this[prop].toString()
        }));

        settings.forEach(({ key, value }) => {
            storage.set({ key, value });
        });
    } 
} 
</script> 

<style>
  .page {
    flex-direction: column;
    align-items: center;
    width: 212px;
    height: 490px;
    background-color: #f5f5f7;
    overflow: hidden;
  }
  .bcg {
    position: absolute;
    width: 212px;
    height: 490px;
    top: 0;
    left: 0;
    z-index: -1;
  }
  .bt {
    position: absolute;
    bottom: 0;
    width: 212px;
    z-index: 5;
  }
  .hd {
    position: absolute;
    top: 0;
    width: 212px;
    z-index: 5;
  }
  .header {
    width: 212px;
    justify-content: center;
    align-items: center;
    margin: 13px 0 10px;
    z-index: 10;
  }
  .title {
    font-size: 30px;
    color: #ebebeb;
    font-weight: bold;
  }
  .scroll {
    width: 202px;
    height: 455px;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }
  .setting-section {
    width: 194px;
    flex-direction: column;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.747);
    border-radius: 9px;
    padding: 10px;
    margin-bottom: 10px;
    border: 1px solid #e0e0e0;
  }
  .section-title {
    font-size: 24px;
    color: #333333;
    font-weight: bold;
    margin-bottom: 8px;
    text-align: center;
  }
  .switch-row {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 8px 0;
  }
  .switch-label {
    font-size: 24px;
    color: #333333;
    font-weight: bold;
    flex: 1;
  }
  .switch-label2 {
    font-size: 20px;
    color: #333333;
    font-weight: bold;
    flex: 1;
  }
  .switch {
    margin-left: 11px;
    height: 22px;
    width: 48px;
  }
  .slider {
    width: 100%;
    margin-top: 8px;
    margin-bottom: 5px;
  }
  .slider-labels {
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    margin-top: 5px;
    margin-bottom: 5px;
  }
  .label {
    font-size: 22px;
    color: #666666;
  }
  .current-value {
    font-size: 22px;
    color: #888888;
    text-align: center;
  }
  .reset {
    font-size: 24px;
    color: #EA6C6C;
    font-weight: bold;
    margin-top: 12px;
    padding: 9px 16px;
    border: 1px solid #EA6C6C;
    border-radius: 8px;
    background-color: rgba(234, 108, 108, 0.1);
  }
  .preview-area {
    width: 100%;
    min-height: 60px;
    background-color: rgba(0, 0, 0, 0.068);
    border-radius: 7px;
    border: 1px solid #e0e0e0;
    padding: 10px;
    margin-top: 8px;
    margin-bottom: 8px;
    justify-content: center;
    align-items: center;
    flex-direction: column;
  }
  .preview-text {
    color: #000000;
    text-align: center;
  }
  .color-picker {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    width: 100%;
    margin-top: 8px;
    margin-bottom: 4px;
  }
  .color-option {
    flex-direction: column;
    align-items: center;
    margin-left: 10px;
    margin-right: 10px;
    padding: 4px;
    border-radius: 7px;
    background-color: rgba(0, 0, 0, 0.03);
    width: 30px;
    position: relative;
  }
  .color-circle {
    width: 28px;
    height: 28px;
    border-radius: 14px;
    border: 1px solid #ddd;
  }
  .color-name {
    font-size: 10px;
    color: #666666;
    margin-top: 3px;
    text-align: center;
  }
  .color-check {
    position: absolute;
    top: 1px;
    right: 1px;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    background-color: #4CAF50;
    color: white;
    font-size: 10px;
    text-align: center;
    line-height: 14px;
  }
  .hint-text {
    font-size: 20px;
    color: #888888;
    text-align: center;
    margin-top: 4px;
  }
  .back-btn-wrap {
    position: absolute;
    bottom: 0;
    width: 212px;
    height: 65px;
    justify-content: center;
    align-items: center;
    z-index: 10;
    background-color: rgba(255, 255, 255, 0.85);
    border: 2px solid #333333;
  }
  .back-btn-text {
    font-size: 26px;
    color: #333333;
    text-align: center;
  }
  .scroll-bottom-space {
    height: 60px;
  }
</style>