    width: 212px;
    justify-content: center;
    align-items: center;
    position: absolute;
    top: 8px;
    z-index: 10;
}

.header-menu {
    position: relative;
    margin-top: 11px;
}

.title {
    font-size: 30px;
    color: #ebebeb;
    font-weight: bold;
}

.content {
    width: 194px;
    justify-content: center;
    align-items: center;
    padding: 10px;
    background-color: rgba(255, 255, 255, 0.726);
    border-radius: 9px;
    border: 1px solid #e0e0e0;
    margin: 9px;
    z-index: 2;
}

.mid {
    font-size: 28px;
    color: #000000;
    font-weight: 800;
}

.cgscroll {
    width: 212px;
    height: 490px;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
}

.cgimg {
    width: 372px;
    height: 490px;
    object-fit: cover;
}

.character {
    position: absolute;
    top: 65px;
    left: 98px;
    width: 140px;
    height: 360px;
    object-fit: contain;
    z-index: 3;
}

.lhscroll {
    width: 212px;
    height: 490px;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
}

.lhcontent {
